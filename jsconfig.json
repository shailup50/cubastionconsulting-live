{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "app/**/*.js",
    "app/**/*.jsx",
    "components/**/*.js",
    "components/**/*.jsx",
    "context/**/*.js",
    "context/**/*.jsx",
    "hooks/**/*.js",
    "hooks/**/*.jsx",
    "lib/**/*.js",
    "lib/**/*.jsx",
    "store/**/*.js",
    "store/**/*.jsx",
    "utils/**/*.js",
    "utils/**/*.jsx",
    "zustand/**/*.js",
    "zustand/**/*.jsx",
    "scripts/**/*.mjs",
    "middleware.js",
    "next.config.js",
    "tailwind.config.js",
    "postcss.config.mjs",
    "eslint.config.mjs",
    "server.mjs"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out"
  ]
}
